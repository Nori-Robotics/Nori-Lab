# Public runtime config for the frozen desktop backend.
#
# The Tauri app spawns the frozen LeLab backend with its working dir set to
# resources/backend/. On boot, backend_entry.py loads a `.env` sitting NEXT TO the
# executable (see _load_adjacent_env). Copy this file to that location as `.env`:
#
#   cp desktop/env.public.example desktop/tauri/resources/backend/.env   # then fill in
#
# and a release build should stage the same file into the bundle (build.sh, step 5).
#
# PUBLIC VALUES ONLY. All three below are browser-safe (the anon key only permits what
# Supabase RLS allows; the URLs are public). NEVER put the Supabase service-role key or
# ANTHROPIC_API_KEY here — a desktop bundle is fully in the customer's hands. The LLM
# path routes through Nori-Backend (Railway), which holds the Anthropic key server-side.

# Supabase project (for browser auth via /nori/config).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# Nori-Backend (Railway) — the JWT proxy target. WITHOUT this the backend defaults to
# http://localhost:8001 (a dev-only default) and all cloud features fail in a shipped app.
NORI_BACKEND_URL=https://nori-backend-production.up.railway.app
