# Frontend build-time config — ONLY for a LeLab-free hosted deploy (the standalone VR page).
#
# The normal app does NOT need these: when served by the LeLab server, config comes from
# `/nori/config` at runtime and these are ignored. Set them only when hosting the bundle
# without a LeLab server behind it (e.g. Vercel / Cloudflare Pages), so bootstrap can fall
# back to build-time values. See DEPLOY_FRONTEND.md.
#
# PUBLIC values only. The anon key already ships to every browser via /nori/config, so
# baking it here is not a secrets leak. NEVER put a Supabase service-role key or any server
# secret in a VITE_ var — it goes straight into the public client bundle.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# Optional: base URL for direct Nori-Backend calls. Leave blank on the VR page — the VR
# drive loop (Supabase signaling + WebRTC) needs no backend proxy; account/marketplace/
# training live in the full LeLab-served app, not the hosted VR surface.
VITE_NORI_BACKEND_URL=

# Public origin where the hosted VR page is served (e.g. https://app.nori.com). The full
# app / desktop bundle bakes this so its "Open in VR headset" link points at the hosted
# page instead of localhost. Leave blank on the hosted build itself (falls back to origin).
VITE_VR_BASE_URL=
