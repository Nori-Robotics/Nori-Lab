# NORI: laptop-app environment. Copy to `.env` and fill in. `.env` is gitignored.
# These are the ONLY Nori vars the laptop needs. Never put HF_TOKEN or the Supabase
# service-role key here — all HF access is mediated by Nori-Backend (see NORI_PLAN.md).

# Base URL for Nori-Backend's /api/v1 surface.
# Local-dev note: LeLab's own server binds :8000, so run Nori-Backend on a different
# port locally, e.g.  `uvicorn main:app --port 8001`  (from ../Nori-Backend/src).
NORI_BACKEND_URL=http://localhost:8001

# Supabase project URL + anon (public) key. Dashboard → Project Settings → API.
# The anon key is safe to expose to the browser; it is served to the React bundle via
# the LeLab `GET /nori/config` endpoint.
SUPABASE_URL=
SUPABASE_ANON_KEY=
